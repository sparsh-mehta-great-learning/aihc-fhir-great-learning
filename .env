# ============================================================
# Host Machine
# ============================================================

HOST=localhost


# ============================================================
# HAPI R4 FHIR Server (Primary Server - ENABLED)
# ============================================================

R4_ENABLED=1
R4_PORT=4004
R4_MEMORY=5g
R4_CPU_CORES=2
R4_IMAGE=smartonfhir/hapi-5:r4-synthea

# ============================================================
# HAPI STU3 FHIR Server (Disabled but MUST have values)
# ============================================================

R3_ENABLED=0
R3_PORT=4003
R3_MEMORY=5g
R3_CPU_CORES=1
R3_IMAGE=smartonfhir/hapi-5:r3-full


# ============================================================
# HAPI DSTU2 FHIR Server (Disabled but MUST have values)
# ============================================================

R2_ENABLED=0
R2_PORT=4002
R2_MEMORY=5g
R2_CPU_CORES=1
R2_IMAGE=smartonfhir/hapi-5:r2-full


# ============================================================
# FHIR Viewer
# ============================================================

FHIR_VIEWER_ENABLED=1
FHIR_VIEWER_PORT=4011


# ============================================================
# Patient Browser
# ============================================================

PATIENT_BROWSER_ENABLED=1
PATIENT_BROWSER_PORT=4012


# ============================================================
# SMART Launcher
# ============================================================

LAUNCHER_ENABLED=1
LAUNCHER_PORT=4013


# ============================================================
# Control Panel (Home Page)
# ============================================================

CONTROL_PANEL_ENABLED=1
CONTROL_PANEL_PORT=4000


# ============================================================
# Clinical Decision Support — n8n Workflow Engine
# ============================================================
# Set N8N_ENABLED=1 to show the CDS panel in the home page.
# n8n will be accessible at http://localhost:4014
#
# IMPORTANT: Change N8N_USER and N8N_PASSWORD before
# exposing this sandbox on any non-loopback interface.
# ============================================================

N8N_ENABLED=1
N8N_PORT=4014
N8N_USER=admin
N8N_EMAIL=admin@example.com
N8N_PASSWORD=Sparsh@123